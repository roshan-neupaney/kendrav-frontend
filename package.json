		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/node": "^4.3.2",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.2",
		"@types/node": "^22",
		"@vitest/browser-playwright": "^4.1.8",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"eslint": "^10.4.1",
